{
  "name": "code_review",
  "description": "Performs automated code review on pull request diffs",
  "inputSchema": {
    "type": "object",
    "properties": {
      "GITHUB_TOKEN": {
        "type": "string",
        "description": "Environment variable: GITHUB_TOKEN"
      }
    },
    "required": [
      "GITHUB_TOKEN"
    ]
  },
  "_interface": {
    "input": "CodeDiff",
    "output": "ReviewReport",
    "context": [
      "Repository",
      "GitHubCredentials"
    ]
  }
}