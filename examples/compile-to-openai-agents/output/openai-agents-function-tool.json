"{\n  \"type\": \"function\",\n  \"function\": {\n    \"name\": \"code_review\",\n    \"description\": \"Performs automated code review on pull request diffs\",\n    \"parameters\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"GITHUB_TOKEN\": {\n          \"type\": \"string\",\n          \"description\": \"Environment variable: GITHUB_TOKEN\"\n        }\n      },\n      \"required\": [\n        \"GITHUB_TOKEN\"\n      ]\n    }\n  },\n  \"_effector\": {\n    \"skillContent\": \"# Code Review\\n\\n## Instructions\\n\\n1. Read the provided code diff\\n2. Analyze for bugs, style issues, and potential improvements\\n3. Return a structured ReviewReport with findings\\n\\n## Examples\\n\\n**Input**: A diff from a pull request adding a new API endpoint\\n**Output**: ReviewReport with severity-tagged findings\",\n    \"interface\": {\n      \"input\": \"CodeDiff\",\n      \"output\": \"ReviewReport\",\n      \"context\": [\n        \"Repository\",\n        \"GitHubCredentials\"\n      ],\n      \"nondeterminism\": null,\n      \"idempotent\": null,\n      \"tokenBudget\": null,\n      \"latencyP50\": null\n    }\n  }\n}"