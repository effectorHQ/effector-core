"{\n  \"name\": \"code-review\",\n  \"version\": \"0.1.0\",\n  \"type\": \"skill\",\n  \"description\": \"Performs automated code review on pull request diffs\",\n  \"interface\": {\n    \"input\": \"CodeDiff\",\n    \"output\": \"ReviewReport\",\n    \"context\": [\n      \"Repository\",\n      \"GitHubCredentials\"\n    ],\n    \"nondeterminism\": null,\n    \"idempotent\": null,\n    \"tokenBudget\": null,\n    \"latencyP50\": null\n  },\n  \"permissions\": {\n    \"network\": true,\n    \"subprocess\": false,\n    \"envRead\": [\n      \"GITHUB_TOKEN\"\n    ],\n    \"envWrite\": [],\n    \"filesystem\": []\n  },\n  \"skillContent\": \"# Code Review\\n\\n## Instructions\\n\\n1. Read the provided code diff\\n2. Analyze for bugs, style issues, and potential improvements\\n3. Return a structured ReviewReport with findings\\n\\n## Examples\\n\\n**Input**: A diff from a pull request adding a new API endpoint\\n**Output**: ReviewReport with severity-tagged findings\"\n}"